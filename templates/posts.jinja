{% extends "partials/_master.jinja" %}

{% block title %}Posts{% endblock %}

{% block content %}
<article>
	<section>
		<h1>Community Posts</h1>
		<p>Share your journey with pictures and text!</p>
	</section>

	<!-- Create Post Form -->
	{% if session.is_some() and not session.get().is_family_session %}
	{% importnimja "partials/_wysiwyg_editor.jinja" %}
	{% endif %}

	<!-- Post Feed -->
	<div class="post-feed-container">
		<h3>Recent Posts</h3>
		<div id="post-feed">
      {% importnimja "post_feed.jinja" %}
		</div>
	</div>
</article>
{% endblock %}

{% block extra_js %}
<script src="/js/wysiwyg.js"></script>
{% endblock %}
