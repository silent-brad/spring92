<!-- WYSIWYG Editor -->
<div class="wysiwyg-container">
	<h3>Create a Post</h3>
	<div id="post-response"></div>
  <form hx-post="/post" hx-target="#post-response" hx-swap="innerHTML" hx-select="unset" hx-encoding="multipart/form-data" id="post-form">
    <label for="text_content">
      <!-- WYSIWYG Toolbar -->
      <div id="wysiwyg-toolbar">
        <button type="button" onclick="formatText('bold')" title="Bold" class="toolbar-btn" data-format="bold">B</button>
        <button type="button" onclick="formatText('italic')" title="Italic" class="toolbar-btn" data-format="italic">I</button>
        <button type="button" onclick="formatText('underline')" title="Underline" class="toolbar-btn" data-format="underline">U</button>
        <button type="button" onclick="formatText('blockquote')" title="Quote" class="toolbar-btn">"</button>
        <button type="button" onclick="insertLink()" title="Link" class="toolbar-btn">
          <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
        </button>
      </div>
      
      <div
        id="text_content_editor"
        contenteditable="true"
        placeholder="Post text here..."
      ></div>
      
      <textarea
        id="text_content"
        name="text_content"
        class="hidden"
      ></textarea>
    </label>
    
    <label for="image">
      Add picture (optional)
      <input
        type="file"
        id="image"
        name="image"
        accept="image/*"
      >
    </label>
    
    <br/>
    <div class="text-right">
      <button type="submit" onclick="updateHiddenTextarea()">Post</button>
    </div>
  </form>
</div>
