{% extends "partials/_master.jinja" %}

{% block title %}Delete Walker Account{% endblock %}

{% block content %}
<article class="delete-page">
	<section>
		<h1>Delete Walker Account</h1>
		<p>Are you absolutely sure you want to delete your walker account?</p>
	</section>
	
	<div id="delete-messages">
	{% if error_message.is_some() %}
		<div class="error solid">
			{{error_message.get()}}
		</div>
	{% endif %}
	</div>
	
	<div class="warning-box">
		<h3>⚠️ This action cannot be undone</h3>
		<p>
			This will permanently delete:
		</p>
		<ul>
			<li>Your walker profile and settings</li>
			<li>All your mile entries and progress</li>
			<li>All your posts and comments</li>
			<li>Your profile picture and uploaded images</li>
		</ul>
	</div>
	
	<form method="post" action="/delete-walker" 
		hx-post="/delete-walker"
		hx-target="#delete-messages"
		hx-swap="innerHTML"
		class="delete-form">
		<button type="submit" class="btn-danger">Yes, delete my account</button>
		<a href="/settings" class="btn-cancel" role="button">Cancel</a>
	</form>
</article>
{% endblock %}
