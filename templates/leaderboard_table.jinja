{% for (rank, user_stat) in user_stats.pairs() %}
	{% let walker = user_stat.walker %}
	<tr>
		<td class="numbers">{{offset + rank + 1}}</td>
		<td>
			{% let name = walker.name %}
			{% let avatar_filename = walker.avatar_filename %}
			{% importnimja "partials/_walker_avatar.jinja" %}
		</td>
		<td><strong class="numbers">{{fmtMiles(user_stat.total_miles)}}</strong></td>
		<td>
			<div class="progress-cell">
				{% let progress_percent = user_stat.progress_percent %}
				<div class="progress-bar-wrap">
					{% importnimja "partials/_progress_bar.jinja" %}
				</div>
				<small class="numbers">{{progress_percent.int}}%</small>
			</div>
		</td>
	</tr>
{% endfor %}
{% if has_more %}
	<tr id="load-more-leaderboard"
		hx-get="/api/leaderboard-table?page={{next_page}}"
		hx-trigger="click"
		hx-target="this"
		hx-swap="outerHTML"
		hx-select="unset"
	>
		<td colspan="4">
			<button class="btn load-more-btn">Load More</button>
		</td>
	</tr>
{% endif %}
