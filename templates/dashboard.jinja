{% extends "partials/_master.jinja" %}

{% block title %}Dashboard{% endblock %}

{% block content %}
<article class="dashboard-container">

	<div class="dashboard-greeting">
		<img
			class="greeting-avatar"
			src="/avatars/{{ session.get().avatar_filename }}"
			alt="{{ session.get().name }} Avatar"
		/>
		<span class="greeting-name">{{ session.get().name }}</span>
	</div>

	<section>
		<h1>Dashboard</h1>
		<p>Track your progress towards the Spring92 goal!</p>
	</section>
	
	{% if error_message.is_some() %}
		<div class="error solid">
			{{error_message.get()}}
		</div>
	{% endif %}
	
	{% if success_message.is_some() %}
		<div class="success solid">
			{{success_message.get()}}
		</div>
	{% endif %}
	
	<!-- Progress Overview -->
	{% if current_total.is_some() %}
		<div class="progress-overview">
			<h2>Your Progress</h2>
			<h3 class="numbers progress-num">{{fmtMiles(current_total.get())}}</h3>
			<p class="numbers progress-num-label">out of 92 miles</p>
			{% if progress_percent.is_some() %}
				{% let progress_percent = progress_percent.get() %}
				{% importnimja "partials/_progress_bar.jinja" %}
				<small class="numbers progress-num-percent">
					{{progress_percent.int}}% complete
				</small>
			{% endif %}
		</div>
	{% endif %}
	
	<div class="dashboard-grid">
		<!-- Log Miles Form -->
		<div class="dashboard-card">
			<h3>Log Miles</h3>
			<form hx-post="/log" hx-target="#log-response" hx-swap="innerHTML" hx-select="unset">
				<label for="miles">
					Miles
					<input
						type="number"
            class="numbers"
						id="miles"
						name="miles"
						step="0.1"
						min="0.1"
						max="50"
						placeholder="Enter miles walked/run"
						{% if miles.isSome() %}value="{{miles.get()}}"{% endif %}
						required
						autofocus
					>
					<small>Enter the number of miles you walked or ran today.</small>
				</label>
				
				<div class="mile-controls">
					<button type="button" onclick="decrementMiles()" class="secondary mile-btn">−</button>
					<button type="button" onclick="incrementMiles()" class="secondary mile-btn">+</button>
				</div>
				
				<button type="submit">Log Miles</button>
			</form>
			<div id="log-response"></div>
		</div>
		
		<!-- Miles Graph -->
		<div class="dashboard-card">
			<h3>Miles Progress</h3>
			<canvas id="milesChart" width="300" height="200"></canvas>
		</div>
	</div>
	
	<!-- Daily Miles List -->
	<div class="activity-container">
		<h3>Recent Activity</h3>
		<div id="daily-miles-list" class="numbers">
			{% if entries_html.len() > 0 %}
				<table>
					<thead>
						<tr>
							<th>Date</th>
							<th>Miles</th>
							<th></th>
						</tr>
					</thead>
					<tbody id="entries-tbody">
						{{entries_html}}
					</tbody>
				</table>
			{% else %}
				<p>No miles logged yet. Log your first miles above!</p>
			{% endif %}
		</div>
		<div id="edit-response"></div>
	</div>
</article>
{% endblock %}

{% block extra_js %}
<script src="/static/js/chart.js"></script>
<script>
(function initDashboard() {

if (typeof Chart === 'undefined') {
	setTimeout(initDashboard, 50);
	return;
}

function incrementMiles() {
	const input = document.getElementById('miles');
	const currentValue = parseFloat(input.value) || 0;
	input.value = (currentValue + 0.5).toFixed(1);
}

function decrementMiles() {
	const input = document.getElementById('miles');
	const currentValue = parseFloat(input.value) || 0;
	if (currentValue > 0.1) {
		input.value = (currentValue - 0.5).toFixed(1);
	}
}

window.incrementMiles = incrementMiles;
window.decrementMiles = decrementMiles;

// Chart setup
const ctx = document.getElementById('milesChart').getContext('2d');

const milesChart = new Chart(ctx, {
	type: 'line',
	data: {
		labels: [],
		datasets: [{
			label: 'Daily Miles',
			data: [],
			borderColor: '#F8F59B',
			backgroundColor: 'rgba(59, 130, 246, 0.1)',
			tension: 0.1,
			fill: true
		}]
	},
	options: {
	  responsive: false,
	  scales: {
		  y: {
			  beginAtZero: true,
			  title: {
				  display: true,
				  text: 'Miles'
			  }
		  },
		  x: {
			  title: {
				  display: true,
				  text: 'Date'
			  }
		  }
	  },
	},
});

function loadChartData() {
	fetch('/api/user-miles-data')
		.then(response => response.json())
		.then(data => {
			if (data.dates && data.miles) {
				milesChart.data.labels = data.dates;
				milesChart.data.datasets[0].data = data.miles;
				milesChart.update();
			}
		})
		.catch(error => {
			console.error('Error loading chart data:', error);
		});
}

function editMiles(entryId, currentMiles) {
	const row = document.getElementById('entry-row-' + entryId);
	if (!row) return;
	const cells = row.querySelectorAll('td');
	cells[1].innerHTML = `<input type="number" id="edit-miles-${entryId}" value="${currentMiles}" step="0.1" min="0.1" max="50" class="numbers edit-miles-input">`;
	cells[2].innerHTML = `
		<div class="edit-form">
			<button class="secondary outline save-btn" onclick="submitEditMiles(${entryId})">Save</button>
			<button class="secondary outline delete-btn-inline" onclick="deleteMiles(${entryId})">Delete</button>
			<button class="secondary outline cancel-btn-inline" onclick="cancelEdit(${entryId}, ${currentMiles})">Cancel</button>
		</div>`;
}

function cancelEdit(entryId, currentMiles) {
	const row = document.getElementById('entry-row-' + entryId);
	if (!row) return;
	const cells = row.querySelectorAll('td');
	cells[1].innerHTML = `<span class="miles-display-${entryId}">${currentMiles}</span>`;
	cells[2].innerHTML = `<button class="secondary outline edit-btn" onclick="editMiles(${entryId}, ${currentMiles})">Edit</button>`;
}

function submitEditMiles(entryId) {
	const miles = document.getElementById('edit-miles-' + entryId).value;
	fetch('/edit-miles', {
		method: 'POST',
		headers: {'Content-Type': 'application/x-www-form-urlencoded'},
		body: 'entry_id=' + entryId + '&miles=' + miles
	}).then(r => r.text()).then(html => {
		document.getElementById('edit-response').innerHTML = html;
		setTimeout(() => { window.location.reload(); }, 1000);
	});
}

function deleteMiles(entryId) {
	if (!confirm('Delete this entry?')) return;
	fetch('/delete-miles', {
		method: 'POST',
		headers: {'Content-Type': 'application/x-www-form-urlencoded'},
		body: 'entry_id=' + entryId
	}).then(r => r.text()).then(html => {
		document.getElementById('edit-response').innerHTML = html;
		setTimeout(() => { window.location.reload(); }, 1000);
	});
}

window.editMiles = editMiles;
window.cancelEdit = cancelEdit;
window.submitEditMiles = submitEditMiles;
window.deleteMiles = deleteMiles;

// Load chart data immediately (works for both initial load and boosted navigation)
loadChartData();

// Reload after successful mile logging
const logResponse = document.getElementById('log-response');
if (logResponse) {
	const observer = new MutationObserver(function() {
		if (logResponse.innerHTML.includes('successfully')) {
			setTimeout(() => { window.location.reload(); }, 1000);
		}
	});
	observer.observe(logResponse, { childList: true });
}

})();
</script>
{% endblock %}
